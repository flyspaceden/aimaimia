// ============================================================
// J 域 — 普通用户系统改造（7 个新模型）
// 参照 plan-treeforuser.md 实施
// ============================================================

// --- J1: 普通用户树节点 ---
model NormalTreeNode {
  id            String            @id @default(cuid())
  rootId        String            // 树标识（单棵树固定为 "ROOT"）
  userId        String?           @unique // null = 系统根节点（Level 0 平台节点）
  parentId      String?
  parent        NormalTreeNode?   @relation("NormalTree", fields: [parentId], references: [id])
  children      NormalTreeNode[]  @relation("NormalTree")
  level         Int               // 0=根节点, 1=第一层用户...
  position      Int               // 在父节点下的位置 (0, 1, 2)
  childrenCount Int               @default(0)
  createdAt     DateTime          @default(now())

  @@unique([parentId, position])        // 防并发插入同位置
  @@index([level, position])            // 层级查询
  @@index([level, childrenCount])       // 插入时找活跃层有空位的父节点
}

// --- J2: 普通用户消费进度 ---
model NormalProgress {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id])
  selfPurchaseCount Int       @default(0) // 在普通树中的有效消费次数
  treeNodeId        String?   // 关联 NormalTreeNode
  frozenAt          DateTime? // 成为VIP时冻结
  updatedAt         DateTime  @updatedAt
}

// --- J3: 普通树有效消费记录 ---
model NormalEligibleOrder {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  orderId        String   @unique
  order          Order    @relation(fields: [orderId], references: [id])
  amount         Float    // 订单利润金额（元）
  effectiveIndex Int?     // k（第几次有效消费）
  valid          Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, valid, createdAt])
  @@index([userId, effectiveIndex])
}

// --- J4: 抽奖奖池配置 ---
model LotteryPrize {
  id            String           @id @default(cuid())
  type          LotteryPrizeType // DISCOUNT_BUY / THRESHOLD_GIFT / NO_PRIZE
  name          String           // 展示名称，如"1元白酒"
  productId     String?          // 关联奖励商品（NO_PRIZE 为 null）
  product       Product?         @relation(fields: [productId], references: [id])
  skuId         String?          // 关联具体SKU
  sku           ProductSKU?      @relation(fields: [skuId], references: [id])
  prizePrice    Float?           // 奖品价格（DISCOUNT_BUY时为特价，THRESHOLD_GIFT时为0）
  originalPrice Float?           // 奖品原价（管理员配置的展示划线价，如蜂蜜市场价）
  threshold     Float?           // 消费门槛（仅 THRESHOLD_GIFT 类型）
  prizeQuantity Int              @default(1) // 奖品数量
  probability   Float            // 中奖概率 (0-100)，所有奖品概率之和=100
  dailyLimit    Int?             // 每日最大中奖数（控制成本）
  totalLimit    Int?             // 总中奖数限制
  wonCount      Int              @default(0) // 已中奖次数
  expirationHours Int?                       // F3: 可配置过期时间（小时），null = 不过期
  isActive      Boolean          @default(true)
  sortOrder     Int              @default(0) // 转盘上的展示顺序
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  records LotteryRecord[]
}

// --- J5: 抽奖记录 ---
model LotteryRecord {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id])
  prizeId   String?             // 中奖的奖品ID（未中奖为null）
  prize     LotteryPrize?       @relation(fields: [prizeId], references: [id])
  result    LotteryResult       // WON / NO_PRIZE
  status    LotteryRecordStatus @default(WON) // 生命周期状态：WON→IN_CART→CONSUMED / WON→EXPIRED / IN_CART→EXPIRED
  drawDate  String              // "2026-02-27"，用于每日次数限制
  meta      Json?               // 奖品快照信息
  createdAt DateTime            @default(now())

  @@index([userId, drawDate]) // 每用户每天可抽多次（次数由配置 lotteryDailyChances 控制）
  @@index([userId, createdAt])
  @@index([status])            // 按状态查询（如查未消费的中奖记录）
}

// --- J6: 平台统一运费规则（替代商户 ShippingTemplate） ---
model ShippingRule {
  id           String   @id @default(cuid())
  name         String   // 规则名称
  regionCodes  String[] // 适用地区行政区划码列表（省级，空=全国）
  minAmount    Float?   // 订单金额下限（含）
  maxAmount    Float?   // 订单金额上限（不含，null=无上限）
  minWeight    Int?     // 商品总重量下限(克)
  maxWeight    Int?     // 商品总重量上限(克)
  fee          Float    // 运费金额
  priority     Int      @default(0) // 优先级（高优先级先匹配）
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// --- J7: 换货请求（替代退款 Refund） ---
model AfterSaleRequest {
  id                    String            @id @default(cuid())
  orderId               String
  order                 Order             @relation(fields: [orderId], references: [id], onDelete: Restrict)
  userId                String
  user                  User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  orderItemId           String?           // 具体商品项（null=整单）
  orderItem             OrderItem?        @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  afterSaleType         AfterSaleType     // 售后类型：无理由退货/质量退货/质量换货
  reasonType            ReplacementReasonType? // 标准化理由类型
  reason                String            // 问题描述（OTHER 时的补充说明）
  photos                String[]          // 照片URL列表（必须上传）
  status                AfterSaleStatus   @default(REQUESTED)
  isPostReplacement     Boolean           @default(false) // 换货后二次售后标记
  arbitrationSource     String?           // 仲裁来源（如"买家申请"/"系统自动"）
  requiresReturn        Boolean           @default(false) // 是否需要买家退回商品
  // 买家退货物流
  returnCarrierName     String?           // 退货快递公司
  returnWaybillNo       String?           // 退货快递单号
  returnShippedAt       DateTime?         // 买家寄出退货时间
  // 卖家验收退货
  sellerRejectReason    String?           // 卖家拒收退货理由
  sellerRejectPhotos    String[]          @default([]) // 卖家拒收退货照片
  sellerReturnWaybillNo String?           // 卖家退回快递单号（拒收退货时回寄）
  // 退款信息
  refundAmount          Float?            // 退款金额（元）
  refundId              String?           // 关联退款记录 ID
  // 审核信息
  reviewerId            String?           // 审核人（卖家staff或管理员）
  reviewNote            String?
  reviewedAt            DateTime?
  approvedAt            DateTime?         // 审批通过时间
  sellerReceivedAt      DateTime?         // 卖家签收退货时间
  // 换货发货（沿用原字段）
  replacementCarrierCode String?
  replacementCarrierName String?
  replacementWaybillNo  String?
  replacementWaybillUrl String?
  replacementSfOrderId String?  // 换货面单顺丰订单ID
  replacementShipmentId String?           // 换货物流单号
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  virtualCallBindings   VirtualCallBinding[] @relation("ReplacementVirtualCallBindings")

  @@map("after_sale_request")
  @@index([orderId])
  @@index([userId, status])
  @@index([status, createdAt])
}

// ============================================================
// K 域 — 平台红包（优惠券）系统（3 个模型）
// 独立于 I 域分润奖励系统，严禁混淆
// ============================================================

// ==========================================
// 平台红包活动（管理员创建的活动/规则）
// ==========================================
model CouponCampaign {
  id                  String                @id @default(uuid())

  // 基本信息
  name                String                // 活动名称（如"2026春节红包"）
  description         String?               // 活动描述
  status              CouponCampaignStatus  @default(DRAFT)

  // 触发与发放
  triggerType          CouponTriggerType     // 触发条件类型
  distributionMode     CouponDistributionMode // 发放方式
  triggerConfig        Json?                 // 触发条件额外配置（如签到天数、消费阈值等）

  // 抵扣规则
  discountType         CouponDiscountType    // FIXED / PERCENT
  discountValue        Float                 // 金额（元）或百分比（0-100）
  maxDiscountAmount    Float?                // 百分比折扣时的最高抵扣额
  minOrderAmount       Float                 @default(0) // 最低消费门槛（0=无门槛）

  // 适用范围
  applicableCategories String[]              @default([]) // 限定品类（空=不限）
  applicableCompanyIds String[]              @default([]) // 限定店铺（空=不限，预留扩展）

  // 叠加规则
  stackable            Boolean               @default(true) // 是否可与同类叠加
  stackGroup           String?               // 叠加分组标识

  // 发放限制
  totalQuota           Int                   // 总发放量
  issuedCount          Int                   @default(0) // 已发放数量
  maxPerUser           Int                   @default(1) // 每人限领

  // 有效期
  validDays            Int                   @default(7)  // 领取后有效天数（0=跟随活动结束时间）
  startAt              DateTime              // 活动开始时间
  endAt                DateTime              // 活动结束时间

  // 审计
  createdBy            String                // 创建管理员 ID
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  // 关联
  instances            CouponInstance[]

  @@index([status, startAt, endAt])
  @@index([triggerType])
}

// ==========================================
// 平台红包实例（用户领取/获得的具体红包）
// ==========================================
model CouponInstance {
  id                  String                @id @default(uuid())

  // 关联
  campaignId          String
  campaign            CouponCampaign        @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  userId              String
  user                User                  @relation("UserCouponInstances", fields: [userId], references: [id], onDelete: Restrict)

  // 状态
  status              CouponInstanceStatus  @default(AVAILABLE)

  // 冗余抵扣信息（快照，避免活动修改后影响已发放红包）
  discountType        CouponDiscountType
  discountValue       Float
  maxDiscountAmount   Float?
  minOrderAmount      Float                 @default(0)

  // 有效期
  issuedAt            DateTime              @default(now()) // 发放时间
  expiresAt           DateTime              // 过期时间

  // 使用记录
  usedAt              DateTime?             // 使用时间
  usedOrderId         String?               // 使用的订单 ID
  usedAmount          Float?                // 实际抵扣金额

  // 审计
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  // 使用记录关联
  usageRecords        CouponUsageRecord[]

  @@index([userId, status])
  @@index([status, expiresAt])
  @@index([campaignId])
  @@index([expiresAt])
  @@unique([campaignId, userId, issuedAt]) // 防止同一活动同一用户同一时刻重复发放
}

// ==========================================
// 平台红包使用记录（一笔订单可使用多张红包）
// ==========================================
model CouponUsageRecord {
  id                  String                @id @default(uuid())

  // 关联
  couponInstanceId    String
  couponInstance      CouponInstance        @relation(fields: [couponInstanceId], references: [id], onDelete: Restrict)
  orderId             String
  order               Order                 @relation("OrderCouponUsage", fields: [orderId], references: [id], onDelete: Restrict)

  // 抵扣详情
  discountAmount      Float                 // 本张红包实际抵扣金额

  // 审计
  createdAt           DateTime              @default(now())

  @@index([orderId])
  @@index([couponInstanceId])
}

// ==========================================
// 平台红包触发事件日志（REVIEW/SHARE 去重）
// ==========================================
model CouponTriggerEvent {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation("UserCouponTriggerEvents", fields: [userId], references: [id], onDelete: Restrict)
  triggerType CouponTriggerType
  eventKey    String
  context     Json?
  createdAt   DateTime          @default(now())

  @@unique([userId, triggerType, eventKey])
  @@index([triggerType, createdAt])
  @@index([userId, triggerType, createdAt])
}

// =============================================
// L 域：VIP 礼包赠品方案
// =============================================
model VipGiftOption {
  id        String              @id @default(cuid())
  title     String              // 方案标题
  subtitle  String?             // 副标题
  coverMode CoverMode           @default(AUTO_GRID) // 封面拼合样式
  coverUrl  String?             // 仅 CUSTOM 模式使用
  badge     String?             // 前台标签
  sortOrder Int                 @default(0)
  status    VipGiftOptionStatus @default(ACTIVE)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  items     VipGiftItem[]       // 组合商品列表

  // 所属档位
  packageId String?
  package   VipPackage? @relation(fields: [packageId], references: [id], onDelete: Restrict)

  @@index([packageId, status, sortOrder])
}

model VipGiftItem {
  id           String        @id @default(cuid())
  giftOptionId String
  giftOption   VipGiftOption @relation(fields: [giftOptionId], references: [id], onDelete: Cascade)
  skuId        String
  sku          ProductSKU    @relation(fields: [skuId], references: [id], onDelete: Restrict)
  quantity     Int           @default(1)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())

  @@unique([giftOptionId, skuId])
  @@index([giftOptionId])
}

// =============================================
// M 域：卖家隐私保护
// =============================================

// 买家匿名编号（每个买家在每个店铺有唯一匿名 ID，防止卖家识别买家身份）
model BuyerAlias {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  alias     String   @unique // 全局唯一，格式: "买家#<6位随机>"
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId]) // 同一买家同一店铺只有一个编号
  @@index([companyId])
}

// 虚拟号绑定记录（卖家通过虚拟中转号联系买家，双方不知道真实号码）
model VirtualCallBinding {
  id              String   @id @default(cuid())
  orderId         String?  // 订单场景
  order           Order?   @relation("OrderVirtualCallBindings", fields: [orderId], references: [id], onDelete: SetNull)
  replacementId   String?  // 售后场景（保留字段名兼容旧数据）
  replacement     AfterSaleRequest? @relation("ReplacementVirtualCallBindings", fields: [replacementId], references: [id], onDelete: SetNull)
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  sellerPhone     String   // 卖家客服电话
  buyerPhone      String   // 买家真实手机号（加密存储）
  virtualNo       String   // 分配的虚拟号
  expireAt        DateTime // 过期时间（24小时）
  staffId         String   // 发起绑定的员工
  createdAt       DateTime @default(now())

  @@index([orderId])
  @@index([replacementId])
  @@index([expireAt])
  @@index([companyId])
}

// M 域：卖家审计日志
model SellerAuditLog {
  id         String   @id @default(cuid())
  staffId    String   // 操作人（CompanyStaff ID）
  companyId  String   // 企业 ID
  action     String   // 操作类型（VIEW_ORDER / SHIP_ORDER / GENERATE_WAYBILL 等）
  module     String   // 模块名（orders / products / replacements 等）
  targetType String?  // 目标实体类型
  targetId   String?  // 目标实体 ID
  ip         String?  // 请求 IP
  userAgent  String?  // User-Agent
  createdAt  DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([staffId, createdAt])
  @@index([action])
}

// =============================================
// N 域：智能客服系统
// =============================================

enum CsTicketCategory {
  LOGISTICS
  AFTERSALE
  PAYMENT
  PRODUCT
  ACCOUNT
  OTHER
}

enum CsTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CsTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum CsSessionStatus {
  AI_HANDLING
  QUEUING
  AGENT_HANDLING
  CLOSED
}

enum CsSessionSource {
  MY_PAGE
  ORDER_DETAIL
  AFTERSALE_DETAIL
}

enum CsMessageSender {
  USER
  AI
  AGENT
  SYSTEM
}

enum CsContentType {
  TEXT
  RICH_CARD
  ACTION_CONFIRM
  ACTION_RESULT
  IMAGE
}

enum CsAgentOnlineStatus {
  ONLINE
  BUSY
  OFFLINE
}

enum CsFaqAnswerType {
  TEXT
  RICH_CARD
}

enum CsQuickEntryType {
  QUICK_ACTION
  HOT_QUESTION
}

model CsTicket {
  id                  String            @id @default(cuid())
  userId              String
  user                User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  category            CsTicketCategory  @default(OTHER)
  priority            CsTicketPriority  @default(MEDIUM)
  status              CsTicketStatus    @default(OPEN)
  summary             String?
  relatedOrderId      String?
  relatedAfterSaleId  String?
  resolvedBy          String?
  resolvedAt          DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  sessions            CsSession[]

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([relatedOrderId])
}

model CsSession {
  id            String           @id @default(cuid())
  ticketId      String?
  ticket        CsTicket?        @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  status        CsSessionStatus  @default(AI_HANDLING)
  source        CsSessionSource
  sourceId      String?
  agentId       String?
  agentJoinedAt DateTime?
  closedAt      DateTime?
  createdAt     DateTime         @default(now())
  messages      CsMessage[]
  rating        CsRating?

  @@index([userId, status])
  @@index([userId, source, sourceId])
  @@index([agentId, status])
  @@index([status, createdAt])
}

model CsMessage {
  id          String          @id @default(cuid())
  sessionId   String
  session     CsSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  senderType  CsMessageSender
  senderId    String?
  contentType CsContentType   @default(TEXT)
  content     String
  metadata    Json?
  routeLayer  Int?
  createdAt   DateTime        @default(now())

  @@index([sessionId, createdAt])
}

model CsAgentStatus {
  id              String              @id @default(cuid())
  adminId         String              @unique
  status          CsAgentOnlineStatus @default(OFFLINE)
  currentSessions Int                 @default(0)
  maxSessions     Int                 @default(5)
  lastActiveAt    DateTime            @default(now())
}

model CsFaq {
  id         String          @id @default(cuid())
  keywords   String[]
  pattern    String?
  answer     String
  answerType CsFaqAnswerType @default(TEXT)
  metadata   Json?
  priority   Int             @default(0)
  enabled    Boolean         @default(true)
  sortOrder  Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([enabled, priority])
}

model CsQuickEntry {
  id        String           @id @default(cuid())
  type      CsQuickEntryType
  label     String
  action    String?
  message   String?
  icon      String?
  enabled   Boolean          @default(true)
  sortOrder Int              @default(0)
}

model CsQuickReply {
  id        String  @id @default(cuid())
  category  String
  title     String
  content   String
  sortOrder Int     @default(0)
  enabled   Boolean @default(true)
}

model CsRating {
  id        String    @id @default(cuid())
  sessionId String    @unique
  session   CsSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  score     Int
  tags      String[]
  comment   String?
  createdAt DateTime  @default(now())
}

