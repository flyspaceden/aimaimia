// 农脉 AI农业电商平台 — 数据库 Schema（全量重建）
// 基于 data-system.md 权威来源
// 设计规则：
// - 主键：String @id @default(cuid())
// - 金额：Float（元），非 data-system.md 的 Int（分）
// - 时间：createdAt / updatedAt
// - 枚举：Prisma 原生 enum
// - 范围：仅买家端 API 需要的表（跳过 Admin/Seller 系统）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 枚举定义
// ============================================================

// --- A 域：认证与用户 ---
enum UserStatus {
  ACTIVE
  BANNED
  DELETED
}

enum AuthProvider {
  PHONE
  WECHAT
  GUEST // @deprecated 游客模式已移除，保留用于清理历史数据（B6），清理完毕后删除此值
}

enum SmsPurpose {
  LOGIN
  BIND
  RESET
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum DevicePlatform {
  IOS
  ANDROID
}

enum Gender {
  UNKNOWN
  MALE
  FEMALE
}

enum ConsentScope {
  PRIVACY_POLICY
  LOCATION
  MICROPHONE
  NOTIFICATION
}

// --- D 域：企业 ---
enum CompanyStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

enum CompanyCreditEventType {
  PRIVACY_VIOLATION
  MANUAL_ADJUSTMENT
}

enum CompanyStaffRole {
  OWNER     // 企业主（创始人，不可移除）
  MANAGER   // 经理（可管理商品+订单+员工）
  OPERATOR  // 运营（只能管理商品+订单，不能管员工）
}

enum CompanyStaffStatus {
  ACTIVE    // 正常
  DISABLED  // 已禁用
}

enum DocumentType {
  LICENSE
  CERT
  INSPECTION
  FOOD_PERMIT
  OTHER
}

enum VerifyStatus {
  PENDING
  VERIFIED
  REJECTED
}

// --- E 域：商品 ---
enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum ProductAuditStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum TagScope {
  COMPANY
  PRODUCT
}

model TagCategory {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  scope       TagScope
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tags        Tag[]
}

enum InventoryType {
  IN
  OUT
  ADJUST
  RESERVE
  RELEASE
}

enum SkuStatus {
  ACTIVE
  INACTIVE
}

// --- F 域：溯源 ---
enum ClaimType {
  CERT
  INSPECTION
  NFT_HASH
  OTHER
}

enum TraceEventType {
  FARMING
  TESTING
  PROCESSING
  PACKAGING
  WAREHOUSE
  SHIPPING
  OTHER
}

// --- G 域：交易 ---
enum CheckoutSessionStatus {
  ACTIVE      // 会话创建，等待支付
  PAID        // 支付确认，正在创建订单
  COMPLETED   // 订单创建成功
  EXPIRED     // 会话超时（30分钟）
  FAILED      // 库存不足等原因失败（已退款）
}

enum CheckoutBizType {
  NORMAL_GOODS  // 普通商品结算
  VIP_PACKAGE   // VIP 礼包结算
}

enum OrderBizType {
  NORMAL_GOODS  // 普通商品订单
  VIP_PACKAGE   // VIP 礼包订单
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  SHIPPED
  DELIVERED
  RECEIVED
  CANCELED
  REFUNDED
}

enum PaymentChannel {
  WECHAT_PAY
  ALIPAY
  UNIONPAY
  AGGREGATOR
}

enum PaymentScene {
  APP
  H5
  JSAPI
  MINI_PROGRAM
}

enum PaymentStatus {
  INIT
  PENDING
  PAID
  FAILED
  CLOSED
  REFUNDED
  PART_REFUNDED
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  REFUNDING
  REFUNDED
  FAILED
}

enum ShipmentStatus {
  INIT
  SHIPPED
  IN_TRANSIT
  DELIVERED
  EXCEPTION
}

enum ShippingCalcType {
  WEIGHT
  COUNT
  AMOUNT
}

// --- G 域扩展：发票 ---
enum InvoiceType {
  PERSONAL
  COMPANY
}

enum InvoiceStatus {
  REQUESTED
  ISSUED
  FAILED
  CANCELED
}

// --- H 域：AI ---
enum AsrProvider {
  IFLYTEK
  BAIDU
  TENCENT
  ALI
  OTHER
}

enum AiActionType {
  NAVIGATE
  CALL_API
  SHOW_CHOICES
}

// --- I 域：会员红包 ---
enum MemberTier {
  NORMAL
  VIP
}

enum VipPurchaseStatus {
  PAID
  REFUNDED
}

enum VipGiftOptionStatus {
  ACTIVE    // 上架，前台可选
  INACTIVE  // 下架，前台不可选
}

model VipPackage {
  id                String              @id @default(cuid())
  price             Float               // 档位价格（元），如 399 / 899 / 1599
  referralBonusRate Float               @default(0.15) // 推荐奖励比例，0.15 = 15%
  sortOrder         Int                 @default(0)
  status            VipGiftOptionStatus @default(ACTIVE) // 复用 ACTIVE/INACTIVE
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  giftOptions       VipGiftOption[]

  @@index([status, sortOrder])
}

enum CoverMode {
  AUTO_GRID      // 宫格拼图（默认）
  AUTO_DIAGONAL  // 对角线分割
  AUTO_STACKED   // 层叠卡片
  CUSTOM         // 自定义上传
}

enum VipActivationStatus {
  PENDING     // 支付已确认，待进入激活流程
  ACTIVATING  // 正在执行 VIP 开通事务
  SUCCESS     // 开通成功
  FAILED      // 激活失败，等待人工处理或重试
  RETRYING    // 自动补偿重试中
}

enum RewardAccountType {
  VIP_REWARD          // VIP分润奖励
  NORMAL_REWARD       // 普通用户分润奖励
  POINTS
  FUND_POOL
  PLATFORM_PROFIT
  INDUSTRY_FUND       // 产业基金（卖家）
  CHARITY_FUND        // 慈善基金
  TECH_FUND           // 科技基金
  RESERVE_FUND        // 备用金
}

enum AllocationTriggerType {
  ORDER_PAID
  ORDER_RECEIVED
  REFUND
}

enum AllocationRuleType {
  NORMAL_BROADCAST  // @deprecated 废弃：滑动窗口分配，保留用于历史数据
  NORMAL_TREE       // 普通用户树分配（替代 NORMAL_BROADCAST）
  VIP_UPSTREAM
  VIP_PLATFORM_SPLIT // VIP 平台分成（百分比与普通 PLATFORM_SPLIT 不同）
  PLATFORM_SPLIT
  ZERO_PROFIT       // M03: 零利润订单幂等标记
}

enum RewardEntryType {
  FREEZE
  RELEASE
  WITHDRAW
  VOID
  ADJUST
}

enum RewardLedgerStatus {
  FROZEN
  AVAILABLE
  WITHDRAWN
  VOIDED
  RESERVED    // F1: 结算会话中预留红包
  RETURN_FROZEN // 售后退货冻结，待退款完成后释放或扣回
}

enum WithdrawChannel {
  WECHAT
  ALIPAY
  BANKCARD
}

enum WithdrawStatus {
  REQUESTED
  APPROVED
  REJECTED
  PAID
  FAILED
}

// --- J 域：普通用户系统改造 ---
enum LotteryPrizeType {
  DISCOUNT_BUY      // 低价买高价商品（如1元白酒）
  THRESHOLD_GIFT    // 消费满X送商品
  NO_PRIZE          // 谢谢参与
}

enum LotteryResult {
  WON
  NO_PRIZE
}

// 抽奖记录生命周期状态
enum LotteryRecordStatus {
  WON        // 已中奖，尚未加入购物车
  IN_CART    // 已加入购物车
  EXPIRED    // 已过期（购物车中超时）
  CONSUMED   // 已消费（订单已创建）
}

enum ReplacementStatus {
  REQUESTED         // 用户提交
  UNDER_REVIEW      // 审核中
  APPROVED          // 已批准，待发货
  SHIPPED           // 已重新发货
  COMPLETED         // 用户确认收到
  REJECTED          // 驳回
}

// --- 统一售后系统枚举 ---
enum AfterSaleType {
  NO_REASON_RETURN   // 七天无理由退货退款
  QUALITY_RETURN     // 质量问题退货退款
  QUALITY_EXCHANGE   // 质量问题换货
}

enum AfterSaleStatus {
  REQUESTED            // 用户提交申请
  UNDER_REVIEW         // 卖家审核中
  APPROVED             // 已批准
  REJECTED             // 卖家驳回
  PENDING_ARBITRATION  // 申请平台仲裁
  RETURN_SHIPPING      // 买家退货寄回中
  RECEIVED_BY_SELLER   // 卖家已收到退货
  SELLER_REJECTED_RETURN // 卖家验收退货不合格
  REFUNDING            // 退款处理中
  REFUNDED             // 退款完成
  REPLACEMENT_SHIPPED  // 换货已发出
  COMPLETED            // 售后完成
  CLOSED               // 系统关闭（超时等）
  CANCELED             // 用户主动取消
}

enum ReturnPolicy {
  RETURNABLE       // 支持七天无理由退货
  NON_RETURNABLE   // 不支持退货（如生鲜）
  INHERIT          // 继承上级品类设置
}

// 换货/退款标准化理由类型（防止买家在自由文本中泄露联系方式）
enum ReplacementReasonType {
  QUALITY_ISSUE      // 质量问题
  WRONG_ITEM         // 发错商品
  DAMAGED            // 运输损坏
  NOT_AS_DESCRIBED   // 与描述不符
  SIZE_ISSUE         // 规格不符
  EXPIRED            // 临期/过期
  OTHER              // 其他（允许附加过滤后的文字）
}

// --- B 域：管理后台 ---
// 审核工作流目标类型
enum ReviewTargetType {
  COMPANY
  DOCUMENT
  PRODUCT
  TRACE
  WITHDRAW
}

// 审核状态
enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AdminUserStatus {
  ACTIVE
  DISABLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  REFUND
  SHIP
  CONFIG_CHANGE
  ROLLBACK
}

// --- 保留模块 ---
enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
  INVITED
  JOINED
  PAID
}

enum GroupStatus {
  FORMING
  INVITING
  FULL
  DEPARTED
  CANCELED
}

enum FollowType {
  USER
  COMPANY
}

// --- K 域：平台红包（优惠券）系统 ---
// 红包活动状态
enum CouponCampaignStatus {
  DRAFT        // 草稿
  ACTIVE       // 进行中
  PAUSED       // 已暂停
  ENDED        // 已结束
}

// 抵扣类型
enum CouponDiscountType {
  FIXED        // 固定金额（如减10元）
  PERCENT      // 百分比折扣（如打9折）
}

// 触发类型
enum CouponTriggerType {
  REGISTER          // 新用户注册
  FIRST_ORDER       // 首次下单
  BIRTHDAY          // 生日
  CHECK_IN          // 签到
  INVITE            // 邀请新用户
  REVIEW            // 好评
  SHARE             // 分享
  CUMULATIVE_SPEND  // 累计消费
  WIN_BACK          // 复购激励
  HOLIDAY           // 节日活动
  FLASH             // 限时抢
  MANUAL            // 手动发放
}

// 发放方式
enum CouponDistributionMode {
  AUTO              // 系统自动发放到用户账户
  CLAIM             // 用户主动领取
  MANUAL            // 管理员手动指定发放
}

// 红包实例状态
enum CouponInstanceStatus {
  AVAILABLE         // 可用
  RESERVED          // 已锁定（结算中）
  USED              // 已使用
  EXPIRED           // 已过期
  REVOKED           // 已撤回（管理员操作）
}

// ============================================================
// A 域 — 认证与用户（8 个 model）
// ============================================================

model User {
  id                     String     @id @default(cuid())
  status                 UserStatus @default(ACTIVE)
  hasAgreedReturnPolicy  Boolean    @default(false) // 是否已同意退货政策
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  // 关系
  profile        UserProfile?
  authIdentities AuthIdentity[]
  sessions       Session[]
  devices        Device[]
  loginEvents    LoginEvent[]
  consents       UserConsent[]

  // G 域关系
  addresses       Address[]
  cart            Cart?
  orders          Order[]
  paymentGroups   PaymentGroup[]
  invoiceProfiles InvoiceProfile[]

  // H 域关系
  aiSessions AiSession[]

  // I 域关系
  memberProfile      MemberProfile?
  vipPurchase        VipPurchase?
  referralsMade      ReferralLink[]      @relation("inviter")
  referralReceived   ReferralLink?       @relation("invitee")
  vipProgress        VipProgress?
  vipEligibleOrders  VipEligibleOrder[]
  rewardAccounts     RewardAccount[]
  rewardLedgers      RewardLedger[]
  normalQueueMembers NormalQueueMember[] // @deprecated 废弃：滑动窗口
  withdrawRequests   WithdrawRequest[]

  // J 域关系（普通用户系统改造）
  normalProgress       NormalProgress?
  normalEligibleOrders NormalEligibleOrder[]
  lotteryRecords       LotteryRecord[]
  afterSaleRequests    AfterSaleRequest[]
  checkoutSessions     CheckoutSession[]

  // 保留模块关系
  bookings        Booking[]
  followsGiven    Follow[]         @relation("follower")
  inboxMessages   InboxMessage[]
  taskCompletions TaskCompletion[]
  checkIns        CheckIn[]

  // K 域关系（平台红包）
  couponInstances     CouponInstance[]   @relation("UserCouponInstances")
  couponTriggerEvents CouponTriggerEvent[] @relation("UserCouponTriggerEvents")

  // 卖家域关系
  companyStaffs   CompanyStaff[]   // 一个用户可以是多家企业的员工
  buyerAliases    BuyerAlias[]     // 在各店铺的匿名编号

  // N 域关系（智能客服）
  csTickets    CsTicket[]
  csSessions   CsSession[]
}

model UserProfile {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nickname             String?
  avatarUrl            String?
  gender               Gender?
  birthday             DateTime? @db.Date
  city                 String?
  // 游戏化字段（从旧 User 表迁移）
  level                String    @default("新芽会员")
  levelProgress        Float     @default(0)
  growthPoints         Int       @default(0)
  nextLevelPoints      Int       @default(1000)
  points               Int       @default(0)
  interests            String[]  @default([])
  avatarFrameType      String? // 头像框类型，合并自旧 AvatarFrame 表
  avatarFrameLabel     String?
  avatarFrameExpiresAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model AuthIdentity {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   AuthProvider
  identifier String // PHONE: 手机号, WECHAT: openId
  unionId    String? // 微信 unionId（跨应用统一）
  appId      String? // 微信应用 appId
  verified   Boolean      @default(false)
  meta       Json? // 微信昵称头像快照等
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([provider, identifier, appId])
  @@index([userId, provider])
}

model SmsOtp {
  id        String     @id @default(cuid())
  phone     String
  purpose   SmsPurpose
  codeHash  String // 不存明文验证码
  expiresAt DateTime
  usedAt    DateTime?
  ip        String?
  createdAt DateTime   @default(now())

  @@index([phone, createdAt])
  @@index([expiresAt])
}

model Session {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId         String?
  device           Device?       @relation(fields: [deviceId], references: [id])
  accessTokenHash  String? // 不存明文
  refreshTokenHash String // 不存明文
  status           SessionStatus @default(ACTIVE)
  expiresAt        DateTime
  absoluteExpiresAt DateTime?    // Refresh Token 最大续期上限（L1）
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([userId, status])
  @@index([expiresAt])
}

model Device {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform    DevicePlatform
  deviceModel String?
  osVersion   String?
  appVersion  String?
  pushToken   String? // 极光/华为/小米/苹果推送
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  sessions Session[]

  @@index([userId, platform])
}

model LoginEvent {
  id           String       @id @default(cuid())
  userId       String?
  user         User?        @relation(fields: [userId], references: [id])
  provider     AuthProvider
  phone        String?
  wechatOpenId String?
  success      Boolean
  ip           String?
  userAgent    String?
  meta         Json?
  createdAt    DateTime     @default(now())

  @@index([userId])
}

model UserConsent {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope     ConsentScope
  granted   Boolean
  version   String // 隐私政策版本
  grantedAt DateTime
  createdAt DateTime     @default(now())
}

// ============================================================
// B 域 — 平台配置（仅 2 个 model，跳过 Admin 系统）
// ============================================================

model RuleConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model RuleVersion {
  id               String     @id @default(cuid())
  version          String     @unique // hash/时间戳
  snapshot         Json // 全量配置快照
  createdByAdminId String?
  createdByAdmin   AdminUser? @relation(fields: [createdByAdminId], references: [id])
  changeNote       String?
  createdAt        DateTime   @default(now())
}

// ============================================================
// B 域 — 管理后台（7 个 model）
// ============================================================

model AdminUser {
  id             String          @id @default(cuid())
  username       String          @unique
  phone          String?         @unique // 新增：管理员手机号（用于短信验证码登录，C18）
  passwordHash   String
  realName       String?
  status         AdminUserStatus @default(ACTIVE)
  loginFailCount Int             @default(0)
  lockedUntil    DateTime?
  lastLoginAt    DateTime?
  lastLoginIp    String?
  createdByAdminId String?
  createdByAdmin   AdminUser?    @relation("AdminCreator", fields: [createdByAdminId], references: [id])
  createdAdmins    AdminUser[]   @relation("AdminCreator")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // 关系
  userRoles      AdminUserRole[]
  sessions       AdminSession[]
  auditLogs      AdminAuditLog[]   @relation("AuditAuthor")
  rollbackLogs   AdminAuditLog[]   @relation("RollbackAuthor")
  ruleVersions   RuleVersion[]
  reviewedWithdraws WithdrawRequest[]
  reviewTasks       ReviewTask[]
}

model AdminRole {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) // 系统角色不可删除
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关系
  userRoles       AdminUserRole[]
  rolePermissions AdminRolePermission[]
}

model AdminPermission {
  id          String @id @default(cuid())
  code        String @unique // 如 orders:read, products:update
  module      String // 模块名
  action      String // 操作名
  description String?

  // 关系
  rolePermissions AdminRolePermission[]
}

model AdminUserRole {
  id          String    @id @default(cuid())
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  roleId      String
  role        AdminRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([adminUserId, roleId])
}

model AdminRolePermission {
  id           String          @id @default(cuid())
  roleId       String
  role         AdminRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   AdminPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())

  @@unique([roleId, permissionId])
}

model AdminAuditLog {
  id              String      @id @default(cuid())
  adminUserId     String
  adminUser       AdminUser   @relation("AuditAuthor", fields: [adminUserId], references: [id])
  action          AuditAction
  module          String // 模块名：orders, products, users...
  targetType      String? // 目标实体类型：Order, Product, User...
  targetId        String? // 目标实体 ID
  summary         String? // 操作摘要
  before          Json? // 变更前快照
  after           Json? // 变更后快照
  diff            Json? // 字段级变化
  ip              String?
  userAgent       String?
  isReversible    Boolean     @default(true)
  rolledBackAt    DateTime?
  rolledBackByAdminId String?
  rolledBackByAdmin   AdminUser? @relation("RollbackAuthor", fields: [rolledBackByAdminId], references: [id])
  rollbackOfLogId String? // 回滚的原始日志 ID
  requestId       String?     // 请求追踪 ID（L10）
  createdAt       DateTime    @default(now())

  @@index([adminUserId, createdAt])
  @@index([module, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([createdAt])
}

model AdminSession {
  id               String    @id @default(cuid())
  adminUserId      String
  adminUser        AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  ip               String?
  userAgent        String?
  expiresAt        DateTime
  absoluteExpiresAt DateTime? // Refresh Token 最大续期上限（L1）
  createdAt        DateTime  @default(now())

  @@index([adminUserId])
  @@index([expiresAt])
}

// --- B4. 审核工作流（统一审核：企业/证件/商品/溯源/提现） ---
model ReviewTask {
  id               String           @id @default(cuid())
  targetType       ReviewTargetType // 审核目标类型
  targetId         String           // 目标实体 ID（Company/Product/WithdrawRequest 等）
  status           ReviewStatus     @default(PENDING)
  reviewerAdminId  String?
  reviewerAdmin    AdminUser?       @relation(fields: [reviewerAdminId], references: [id])
  reason           String?          // 审核意见/驳回原因
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([status, createdAt])
  @@index([targetType, targetId])
}

// ============================================================
// D 域 — 企业（4 个 model）
// ============================================================

model Company {
  id            String        @id @default(cuid())
  name          String
  shortName     String?
  description   String? // AI/搜索摘要
  status        CompanyStatus @default(PENDING)
  contact       Json? // 联系信息
  servicePhone  String?
  serviceWeChat String?
  address       Json? // 经营地址/地图POI {lng,lat,text}
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  isPlatform    Boolean       @default(false) // 平台官方公司标记

  // 关系
  profile           CompanyProfile?
  documents         CompanyDocument[]
  activities        CompanyActivity[]
  products          Product[]
  traceBatches      TraceBatch[]
  shippingTemplates ShippingTemplate[]

  // 保留模块关系
  groups   Group[]
  bookings Booking[]

  // 卖家域关系
  staff        CompanyStaff[]   // 企业员工列表
  buyerAliases BuyerAlias[]     // 买家匿名编号
  virtualCallBindings VirtualCallBinding[] // 虚拟号绑定记录
  shipments    Shipment[]

  creditScore  Int          @default(100)  // 企业信用分（初始100，违规扣减）
  virtualCallRestrictedUntil DateTime?
  suspendedUntil DateTime?
  creditEvents CompanyCreditEvent[]
  companyTags   CompanyTag[]
}

model CompanyProfile {
  id          String   @id @default(cuid())
  companyId   String   @unique
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  richContent Json? // 富文本内容
  highlights  Json? // 结构化卖点：产地、认证、主营、关键词
  updatedAt   DateTime @updatedAt
}

model CompanyDocument {
  id           String       @id @default(cuid())
  companyId    String
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type         DocumentType
  title        String
  fileUrl      String
  issuer       String?
  issuedAt     DateTime?
  expiresAt    DateTime?
  verifyStatus VerifyStatus @default(PENDING)
  verifyNote   String?
  createdAt    DateTime     @default(now())

  @@index([companyId])
}

enum MerchantApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model MerchantApplication {
  id             String                      @id @default(cuid())
  companyName    String
  category       String
  contactName    String
  phone          String
  email          String?
  licenseFileUrl String
  status         MerchantApplicationStatus   @default(PENDING)
  rejectReason   String?
  reviewedAt     DateTime?
  reviewedBy     String?
  companyId      String?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  @@index([status])
  @@index([phone])
}

model CompanyCreditEvent {
  id          String                 @id @default(cuid())
  companyId   String
  company     Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        CompanyCreditEventType
  scoreDelta  Int
  reason      String
  sourceType  String?
  sourceRefId String?
  metadata    Json?
  createdAt   DateTime               @default(now())

  @@index([companyId, createdAt])
  @@index([companyId, type, createdAt])
  @@index([companyId, sourceType, sourceRefId])
}

model CompanyActivity {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title     String
  content   Json? // 活动详情
  startAt   DateTime?
  endAt     DateTime?
  createdAt DateTime  @default(now())

  @@index([companyId])
}

// --- 企业员工关联表 ---
model CompanyStaff {
  id        String             @id @default(cuid())
  userId    String
  companyId String
  role      CompanyStaffRole   @default(OPERATOR)
  status    CompanyStaffStatus @default(ACTIVE)
  passwordHash String?         // 新增：卖家员工密码登录（OWNER 创建员工时设定），C17；nullable 兼容历史仅短信登录员工
  invitedBy String?            // 邀请人 userId（OWNER/MANAGER）
  joinedAt  DateTime           @default(now())
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict) // H17/M6: 防止删除有员工关联的用户
  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict) // H17/M6: 防止删除有员工关联的企业

  sellerSessions SellerSession[]

  @@unique([userId, companyId]) // 同一用户在同一企业只有一个角色
  @@index([companyId])
  @@index([userId])
}

// --- 卖家会话管理 ---
model SellerSession {
  id               String        @id @default(cuid())
  staffId          String        // CompanyStaff.id
  staff            CompanyStaff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  ip               String?
  userAgent        String?
  expiresAt        DateTime
  absoluteExpiresAt DateTime?    // Refresh Token 最大续期上限（L1）
  createdAt        DateTime      @default(now())

  @@index([staffId])
  @@index([expiresAt])
}

// ============================================================
// E 域 — 商品（7 个 model）
// ============================================================

model Category {
  id           String       @id @default(cuid())
  parentId     String?
  parent       Category?    @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[]   @relation("CategoryTree")
  name         String
  path         String       @unique // 树路径
  level        Int
  sortOrder    Int          @default(0)
  isActive     Boolean      @default(true)
  returnPolicy ReturnPolicy @default(INHERIT) // 退货政策：继承上级/支持/不支持

  products Product[]
}

model Tag {
  id         String      @id @default(cuid())
  name       String
  categoryId String
  category   TagCategory @relation(fields: [categoryId], references: [id])
  synonyms   String[]    @default([])
  sortOrder  Int         @default(0)
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())

  productTags ProductTag[]
  companyTags CompanyTag[]

  @@unique([name, categoryId])
  @@index([categoryId])
}

model CompanyTag {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  sortOrder Int     @default(0)

  @@unique([companyId, tagId])
  @@index([companyId])
  @@index([tagId])
}

model Product {
  id                 String             @id @default(cuid())
  companyId          String
  company            Company            @relation(fields: [companyId], references: [id])
  categoryId         String?
  category           Category?          @relation(fields: [categoryId], references: [id])
  title              String
  subtitle           String?
  description        String?
  detailRich         Json? // 富文本详情
  status             ProductStatus      @default(DRAFT)
  auditStatus        ProductAuditStatus @default(PENDING)
  auditNote          String?
  basePrice          Float // 基础价格（元）
  cost               Float? // 成本价（元）
  currency           String             @default("CNY")
  origin             Json? // 产地/坐标/行政区划
  attributes         Json? // 自定义属性
  aiKeywords         String[]           @default([])
  // 语义匹配字段（AI 辅助填充 + 人工可改）
  flavorTags      String[]           @default([])
  seasonalMonths  Int[]              @default([])
  usageScenarios  String[]           @default([])
  dietaryTags     String[]           @default([])
  originRegion    String?
  shippingTemplateId String?
  shippingTemplate   ShippingTemplate?  @relation(fields: [shippingTemplateId], references: [id])
  returnPolicy       ReturnPolicy       @default(INHERIT) // 退货政策：继承品类/支持/不支持
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // 关系
  skus              ProductSKU[]
  media             ProductMedia[]
  tags              ProductTag[]
  productTraceLinks ProductTraceLink[]
  lotteryPrizes     LotteryPrize[]

  @@index([companyId, status, createdAt]) // 卖家商品列表查询
  @@index([status, createdAt]) // 买家商品列表按状态+时间过滤
}

model ProductSKU {
  id         String    @id @default(cuid())
  productId  String
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  skuCode    String?   @unique
  title      String
  price      Float // 价格（元），卖家商品由系统自动计算 (= cost × markupRate)
  cost       Float     @default(0) // 成本价（元），卖家商品必填，平台/抽奖商品由后台设置
  stock        Int       @default(0)
  maxPerOrder  Int?      // 单笔订单限购数量，null = 不限制
  weightGram Int?
  barcode    String?
  status     SkuStatus @default(ACTIVE)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // 关系
  cartItems        CartItem[]
  orderItems       OrderItem[]
  inventoryLedgers InventoryLedger[]
  lotteryPrizes    LotteryPrize[]
  vipGiftItems     VipGiftItem[]
}

model ProductMedia {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      MediaType
  url       String
  sortOrder Int       @default(0)
  alt       String?

  @@index([productId]) // M5: 外键索引，加速商品媒体查询
}

model ProductTag {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([productId, tagId])
}

model InventoryLedger {
  id        String        @id @default(cuid())
  skuId     String
  sku       ProductSKU    @relation(fields: [skuId], references: [id], onDelete: Cascade)
  type      InventoryType
  qty       Int
  refType   String? // ORDER/ADMIN/IMPORT
  refId     String?
  createdAt DateTime      @default(now())

  @@index([skuId]) // M5: 外键索引，加速库存流水查询
}

// ============================================================
// F 域 — 溯源确权（5 个 model）
// ============================================================

model OwnershipClaim {
  id        String    @id @default(cuid())
  type      ClaimType
  data      Json
  createdAt DateTime  @default(now())

  traceBatches TraceBatch[]
}

model TraceBatch {
  id               String          @id @default(cuid())
  companyId        String
  company          Company         @relation(fields: [companyId], references: [id])
  batchCode        String          @unique
  ownershipClaimId String?
  ownershipClaim   OwnershipClaim? @relation(fields: [ownershipClaimId], references: [id])
  meta             Json? // 产地、养殖方式、饲料、检验摘要等
  createdAt        DateTime        @default(now())

  events              TraceEvent[]
  productTraceLinks   ProductTraceLink[]
  orderItemTraceLinks OrderItemTraceLink[]
}

model TraceEvent {
  id         String         @id @default(cuid())
  batchId    String
  batch      TraceBatch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  type       TraceEventType
  data       Json?
  occurredAt DateTime
  createdAt  DateTime       @default(now())
}

model ProductTraceLink {
  id        String     @id @default(cuid())
  productId String
  product   Product    @relation(fields: [productId], references: [id])
  batchId   String
  batch     TraceBatch @relation(fields: [batchId], references: [id])
  note      String?

  @@unique([productId, batchId])
}

model OrderItemTraceLink {
  id          String     @id @default(cuid())
  orderItemId String
  orderItem   OrderItem  @relation(fields: [orderItemId], references: [id])
  batchId     String
  batch       TraceBatch @relation(fields: [batchId], references: [id])
  quantity    Int
  createdAt   DateTime   @default(now())

  @@index([orderItemId])
}

// ============================================================
// G 域 — 交易（12 个 model，跳过 Invoice 系列）
// ============================================================

model Address {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  recipientName String
  phone         String
  regionCode    String // 行政区划 code
  regionText    String // "广东省深圳市南山区"
  detail        String
  location      Json? // {lng,lat,provider:AMAP/TENCENT}
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt

  items CartItem[]
}

model CartItem {
  id            String     @id @default(cuid())
  cartId        String
  cart          Cart       @relation(fields: [cartId], references: [id], onDelete: Cascade)
  skuId         String
  sku           ProductSKU @relation(fields: [skuId], references: [id])
  quantity      Int
  isPrize       Boolean    @default(false)   // 是否为抽奖奖品
  prizeRecordId String?    @unique           // 关联 LotteryRecord.id，唯一约束防止同一奖品重复加入购物车
  isLocked      Boolean    @default(false)   // F2: THRESHOLD_GIFT 未达门槛时锁定
  threshold     Float?                       // F2: 解锁门槛金额（缓存自 LotteryPrize.threshold）
  isSelected    Boolean    @default(true)    // F2: 用户是否勾选该商品（用于部分结算）
  createdAt     DateTime   @default(now())   // F2/F3: 入购物车时间（奖品过期起算点）
  expiresAt     DateTime?                    // F3: 奖品过期时间，非奖品为 null

  @@index([cartId, skuId]) // 替换 @@unique：奖品项可能与普通项 SKU 相同
  @@index([expiresAt])     // F3: 过期清理查询优化
}

model CheckoutSession {
  id              String                @id @default(cuid())
  userId          String
  user            User                  @relation(fields: [userId], references: [id])
  status          CheckoutSessionStatus @default(ACTIVE)
  bizType         CheckoutBizType       @default(NORMAL_GOODS) // 业务类型：普通商品 / VIP 礼包
  bizMeta         Json?                 // 业务元数据，VIP_PACKAGE 时存储 {vipGiftOptionId, giftTitle, giftCoverMode, giftCoverUrl, giftBadge, itemCount, snapshotPrice, shippingFeeMode, inventoryReserved}

  // 结算快照（创建时冻结）
  itemsSnapshot   Json                  // [{skuId, quantity, cartItemId?, isPrize, prizeRecordId?, unitPrice, companyId}]
  addressSnapshot Json                  // 完整地址快照
  rewardId        String?  @map("redPackId") // 选用的分润奖励 ID（列名兼容旧 redPackId）
  expectedTotal   Float                 // 服务端计算的应付总额
  goodsAmount     Float                 // 商品金额
  shippingFee     Float                 // 运费
  discountAmount  Float    @default(0)  // 分润奖励抵扣
  vipDiscountAmount Float  @default(0) // VIP折扣金额（元），平台补贴

  // 支付信息
  merchantOrderNo String?  @unique      // 预生成的商户订单号
  paymentChannel  PaymentChannel?
  providerTxnId   String?  @unique      // 支付渠道返回的交易号

  // 平台红包
  couponInstanceIds   String[]  @default([]) // 选中的平台红包实例 ID 列表
  totalCouponDiscount Float     @default(0)  // 平台红包总抵扣金额
  couponPerAmounts    Json?                // 逐张红包抵扣金额快照 [{ couponInstanceId, discountAmount }]

  // 幂等
  idempotencyKey  String?

  expiresAt       DateTime              // ACTIVE 会话 30 分钟后过期
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders          Order[]               // 支付成功后创建的订单

  @@index([userId, status])
  @@index([status, createdAt])
  @@unique([userId, idempotencyKey])
  @@index([merchantOrderNo])
  @@index([expiresAt, status])
}

model Order {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Restrict) // H17: 防止删除有订单的用户
  status          OrderStatus  @default(PENDING_PAYMENT)
  bizType         OrderBizType @default(NORMAL_GOODS) // 业务类型：普通商品 / VIP 礼包
  bizMeta         Json?        // 业务元数据，VIP_PACKAGE 时存储 {vipGiftOptionId, giftTitle, giftCoverMode, giftCoverUrl, giftBadge, itemCount, snapshotPrice, shippingFeeMode, inventoryReserved}
  addressSnapshot Json? // 下单时地址快照
  totalAmount     Float // 总金额（元）
  goodsAmount     Float // 商品金额（元）
  shippingFee     Float       @default(0) // 运费（元）
  discountAmount  Float       @default(0) // 优惠金额（元）
  vipDiscountAmount Float  @default(0) // VIP折扣金额（元），平台补贴
  checkoutSessionId String?
  checkoutSession   CheckoutSession? @relation(fields: [checkoutSessionId], references: [id])
  idempotencyKey  String?     @unique // 幂等键，防止重复创建订单
  paidAt                  DateTime?
  receivedAt              DateTime?
  autoReceiveAt           DateTime?
  deliveredAt             DateTime?  // 物流签收时间（触发退货窗口计时）
  returnWindowExpiresAt   DateTime?  // 退货窗口截止时间（deliveredAt + N天）
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  deletedAt               DateTime?   // 软删除标记

  // 关系
  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  payments      Payment[]
  refunds            Refund[]
  shipments          Shipment[]
  invoice            Invoice?
  paymentGroupItems  PaymentGroupItem[]

  // I 域关系
  vipPurchase        VipPurchase?
  vipEligibleOrder   VipEligibleOrder?
  rewardAllocations  RewardAllocation[]
  normalQueueMembers NormalQueueMember[] // @deprecated 废弃：滑动窗口

  // J 域关系（普通用户系统改造 + 统一售后）
  normalEligibleOrder NormalEligibleOrder?
  afterSaleRequests   AfterSaleRequest[]
  virtualCallBindings VirtualCallBinding[] @relation("OrderVirtualCallBindings")

  // K 域关系（平台红包）
  couponUsageRecords  CouponUsageRecord[]  @relation("OrderCouponUsage")
  totalCouponDiscount Float?               // 平台红包总抵扣金额

  @@index([userId, status, createdAt]) // 买家订单列表查询
  @@index([status, createdAt]) // 管理端按状态+时间查询
  @@index([createdAt]) // 管理端销售趋势按日期范围查询
}

model OrderItem {
  id              String     @id @default(cuid())
  orderId         String
  order           Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  skuId           String
  sku             ProductSKU @relation(fields: [skuId], references: [id])
  productSnapshot Json? // 下单时商品快照
  unitPrice       Float // 单价（元）
  quantity        Int
  companyId       String? // 冗余加速
  isPrize         Boolean    @default(false) // 是否为抽奖奖品
  prizeType       String? // DISCOUNT_BUY / THRESHOLD_GIFT
  prizeRecordId   String? // 关联 LotteryRecord
  createdAt       DateTime   @default(now())
  deletedAt       DateTime?  // 软删除标记

  orderItemTraceLinks OrderItemTraceLink[]
  // H02修复：关联退款明细行
  refundItems          RefundItem[]
  afterSaleRequests    AfterSaleRequest[]

  @@index([orderId]) // 订单商品项查询
}

model OrderStatusHistory {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus String
  toStatus   String
  reason     String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([orderId])
}

model Payment {
  id               String         @id @default(cuid())
  orderId          String
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Restrict) // H17: 防止删除有支付记录的订单
  channel          PaymentChannel
  scene            PaymentScene   @default(APP)
  amount           Float // 支付金额（元）
  currency         String         @default("CNY")
  status           PaymentStatus  @default(INIT)
  providerTxnId    String?        @unique // 支付渠道交易号
  merchantOrderNo  String         @unique // 商户订单号
  requestPayload   Json?
  rawNotifyPayload Json? // 回调原文（脱敏/加密）
  paidAt           DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?      // 软删除标记

  @@index([orderId])
}

/// N16修复：合并支付组（拆单后一次支付多个订单）
model PaymentGroup {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  totalAmount     Float         // 合并支付总金额（元）
  channel         PaymentChannel
  status          PaymentStatus @default(INIT)
  merchantGroupNo String        @unique // 合并支付商户单号
  providerTxnId   String?       @unique
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items PaymentGroupItem[]

  @@index([userId])
}

model PaymentGroupItem {
  id             String       @id @default(cuid())
  paymentGroupId String
  paymentGroup   PaymentGroup @relation(fields: [paymentGroupId], references: [id], onDelete: Cascade)
  orderId        String
  order          Order        @relation(fields: [orderId], references: [id])
  amount         Float        // 该订单分摊金额

  @@index([paymentGroupId])
  @@index([orderId])
}

/// @deprecated 废弃：退款流程，由 ReplacementRequest 换货流程替代。保留用于历史数据查询
model Refund {
  id               String       @id @default(cuid())
  orderId          String
  order            Order        @relation(fields: [orderId], references: [id], onDelete: Restrict) // H17/M6: 防止删除有退款记录的订单
  paymentId        String?
  amount           Float // 退款金额（元）
  status           RefundStatus @default(REQUESTED)
  providerRefundId String?      @unique
  merchantRefundNo String       @unique
  rawNotifyPayload Json?
  reason           String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?    // 软删除标记

  // 退款状态变更历史
  statusHistory RefundStatusHistory[]
  // H02修复：商品行级退款明细
  items RefundItem[]

  @@index([orderId])
}

