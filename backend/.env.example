# ═══════════════════════════════════════════════════════════
# 爱买买后端 .env 模板
#
# 三段式环境策略（2026-04-19 确立，详见 plan.md C40c3）:
#   本地开发   : SMS_MOCK=true  + ALIPAY 沙箱 + 走图形验证码
#                （admin/123456、cs-001..010/seller123 直通登录）
#   Staging    : SMS_MOCK=false + ALIPAY 沙箱 + 走图形验证码（真实回归）
#                （模板见 docs/operations/.env.staging）
#   Production : 全部 mock 关闭，真实凭证（见 plan.md C40e checklist）
#
# 复制此文件为 .env 后按本地开发策略调整
# ═══════════════════════════════════════════════════════════

DATABASE_URL="postgresql://user:password@localhost:5432/aimaimai"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-me-to-a-random-string"
JWT_EXPIRES_IN="15m"
PORT=3000

# 管理后台 JWT 密钥（独立于买家 JWT_SECRET，生产环境必须重新生成）
ADMIN_JWT_SECRET="change-me-to-a-random-string-for-admin"

# 卖家后台 JWT 密钥（独立于买家 JWT_SECRET，生产环境必须重新生成）
SELLER_JWT_SECRET="change-me-to-a-random-string-for-seller"

# 支付回调 Webhook 签名密钥（生产环境必须配置）
PAYMENT_WEBHOOK_SECRET="change-me-to-a-random-webhook-secret"

# 物流回调 Webhook 签名密钥（生产环境必须配置）
LOGISTICS_WEBHOOK_SECRET="change-me-to-a-random-webhook-secret"

# Webhook IP 白名单（逗号分隔，支持 CIDR。生产环境必须配置支付宝/顺丰 IP 段）
WEBHOOK_IP_WHITELIST=""

# 微信开放平台（微信登录）
WECHAT_MOCK=true
WECHAT_APP_ID="your-wechat-app-id"
WECHAT_APP_SECRET="your-wechat-app-secret"

# 阿里云短信服务（验证码）
SMS_MOCK=true
SMS_ACCESS_KEY_ID="your-aliyun-access-key-id"
SMS_ACCESS_KEY_SECRET="your-aliyun-access-key-secret"
SMS_SIGN_NAME="your-sms-sign-name"
SMS_TEMPLATE_CODE="SMS_xxxxxxxxx"

# 阿里云邮件推送 DirectMail（邮箱验证码）
EMAIL_SMTP_HOST="smtpdm.aliyun.com"
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER="noreply@mail.ai-maimai.com"
EMAIL_SMTP_PASS="your-smtp-password"

# 阿里云 OSS（图片存储）
UPLOAD_LOCAL=true
OSS_REGION="oss-cn-hangzhou"
OSS_ACCESS_KEY_ID="your-aliyun-access-key-id"
OSS_ACCESS_KEY_SECRET="your-aliyun-access-key-secret"
OSS_BUCKET="your-bucket-name"

# 顺丰丰桥（电子面单 + 物流查询 + 物流推送）
SF_ENV="UAT"
SF_API_URL="https://bsp-oisp.sf-express.com/std/service"
SF_API_URL_UAT="https://sfapi-sbox.sf-express.com/std/service"
SF_CLIENT_CODE="your-sf-client-code"
SF_CHECK_WORD="your-sf-check-word"
SF_MONTHLY_ACCOUNT="your-sf-monthly-account"
SF_CALLBACK_URL="https://api.ai-maimai.com/api/v1/shipments/sf/callback"
SF_TEMPLATE_CODE="fm_150_standard_HNGHAfep"

# 阿里云百炼平台（语音识别 + Qwen 大模型）
DASHSCOPE_API_KEY="your-dashscope-api-key"

# 支付宝支付
# --- 生产环境（证书模式）---
# ALIPAY_APP_ID="2021006144601730"
# ALIPAY_PRIVATE_KEY_PATH="certs/alipay/app-private-key.txt"
# ALIPAY_APP_CERT_PATH="certs/alipay/appCertPublicKey.crt"
# ALIPAY_PUBLIC_CERT_PATH="certs/alipay/alipayCertPublicKey.crt"
# ALIPAY_ROOT_CERT_PATH="certs/alipay/alipayRootCert.crt"
# ALIPAY_NOTIFY_URL="https://api.ai-maimai.com/payments/alipay/notify"
# --- 沙箱环境（公钥模式）---
# ALIPAY_APP_ID="9021000162667503"
# ALIPAY_PRIVATE_KEY="沙箱应用私钥"
# ALIPAY_PUBLIC_KEY="沙箱支付宝公钥"
# ALIPAY_GATEWAY="https://openapi-sandbox.dl.alipaydev.com/gateway.do"
# ALIPAY_ENDPOINT="https://openapi-sandbox.dl.alipaydev.com"
# ALIPAY_NOTIFY_URL="https://your-ngrok-url/payments/alipay/notify"

# 语义意图升级开关
AI_SEMANTIC_SLOTS_ENABLED=false
AI_PRODUCT_SEMANTIC_FIELDS_ENABLED=false
AI_SEMANTIC_SCORING_ENABLED=false
