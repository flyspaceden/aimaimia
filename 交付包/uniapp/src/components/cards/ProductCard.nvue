  font-size: $nm-font-body;
  line-height: $nm-line-body;
  font-weight: 600;
  color: $nm-text-primary;
}

.nm-card__origin {
  margin-top: 6rpx;
  font-size: $nm-font-caption;
  color: $nm-text-secondary;
}

.nm-card__tags {
  margin-top: $nm-space-sm;
  flex-direction: row;
  flex-wrap: wrap;
}

.nm-tag {
  padding: 6rpx 14rpx;
  border-radius: $nm-radius-pill;
  background-color: $nm-background;
  border: 1rpx solid $nm-border;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

.nm-tag__text {
  font-size: $nm-font-caption;
  color: $nm-text-secondary;
}

.nm-card__row {
  margin-top: $nm-space-sm;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.nm-card__price-wrap {
  flex: 1;
}

.nm-card__price-row {
  flex-direction: row;
  align-items: baseline;
}

.nm-card__price {
  font-size: $nm-font-body;
  line-height: $nm-line-body;
  font-weight: 600;
  color: $nm-brand-primary;
}

.nm-card__unit {
  margin-left: 4rpx;
  font-size: $nm-font-caption;
  color: $nm-text-secondary;
}

.nm-card__strike {
  margin-top: 2rpx;
  font-size: $nm-font-caption;
  color: $nm-text-secondary;
  text-decoration: line-through;
}

.nm-card__cart {
  width: 56rpx;
  height: 56rpx;
  border-radius: $nm-radius-pill;
  background-color: $nm-brand-primary;
  align-items: center;
  justify-content: center;
}

.nm-card__cart-icon {
  color: $nm-text-inverse;
}
</style>
