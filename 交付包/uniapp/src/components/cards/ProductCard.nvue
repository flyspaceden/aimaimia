<template>
  <view class="nm-card">
    <image :src="item.image" class="nm-card__image" :style="imageStyle" mode="aspectFill" />
    <view class="nm-card__body">
      <text class="nm-card__title" number-of-lines="2">{{ item.title }}</text>
      <text class="nm-card__origin">{{ item.origin }}</text>
      <view v-if="item.tags && item.tags.length" class="nm-card__tags">
        <view v-for="(tag, index) in item.tags.slice(0, 2)" :key="`${item.id}-${tag}-${index}`" class="nm-tag">
          <text class="nm-tag__text">{{ tag }}</text>
        </view>
      </view>
      <view class="nm-card__row">
        <view class="nm-card__price-wrap">
          <view class="nm-card__price-row">
            <text class="nm-card__price">¥{{ item.price }}</text>
            <text class="nm-card__unit">/{{ item.unit }}</text>
          </view>
          <text v-if="item.strikePrice" class="nm-card__strike">¥{{ item.strikePrice }}</text>
        </view>
        <view class="nm-card__cart" @click.stop="onAddToCart">
          <Icon class="nm-card__cart-icon" name="cart" :size="36" :color="textInverse" />
        </view>
      </view>
    </view>
  </view>
</template>

<script>
import Icon from '@/components/ui/Icon.nvue';
// 商品卡片（nvue）：首页瀑布流使用（公共组件需中文注释）
import { CartState } from '@/services/state';

export default {
  components: { Icon },
  props: {
    item: { type: Object, required: true },
    imageHeight: { type: Number, default: 240 },
  },
  computed: {
    textInverse() {
      return '#FFFFFF';
    },
    imageStyle() {
      return {
        height: `${this.imageHeight}rpx`,
      };
    },
  },
  methods: {
    onAddToCart() {
      // TODO(后端)：后续如改为服务端购物车，这里应调用 CartRepo.addItem，再同步 CartState
      CartState.addProduct(
        { id: this.item.id, title: this.item.title, price: this.item.price, image: this.item.image },
        1
      );
      uni.showToast({ title: '已加入购物车', icon: 'success', duration: 1200 });
    },
  },
};
</script>

<style scoped lang="scss">
