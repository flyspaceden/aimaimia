}

.nm-post__title {
  margin-top: $nm-space-sm;
  font-size: $nm-font-title3;
  line-height: $nm-line-title3;
  font-weight: 600;
  color: $nm-text-primary;
}

.nm-post__content {
  margin-top: 6rpx;
  font-size: $nm-font-body;
  color: $nm-text-secondary;
}

.nm-post__tags {
  margin-top: $nm-space-sm;
  flex-direction: row;
  flex-wrap: wrap;
}

.nm-tag {
  padding: 6rpx 14rpx;
  border-radius: $nm-radius-pill;
  background-color: $nm-background;
  border: 1rpx solid $nm-border;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

.nm-tag__text {
  font-size: $nm-font-caption;
  color: $nm-text-secondary;
}

.nm-post__footer {
  margin-top: $nm-space-sm;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.nm-post__extra {
  margin-top: $nm-space-md;
  padding-top: $nm-space-md;
  border-top: 1rpx solid $nm-border;
}

.nm-post__time {
  font-size: $nm-font-caption;
  color: $nm-text-secondary;
}

.nm-post__actions {
  flex-direction: row;
}

.nm-post__action {
  flex-direction: row;
