  margin-left: $nm-space-sm;
}

.nm-post__action-icon {
  color: $nm-text-secondary;
}

.nm-post__action-text {
  margin-left: 6rpx;
  font-size: $nm-font-caption;
  line-height: $nm-line-caption;
  color: $nm-text-secondary;
}
</style>
