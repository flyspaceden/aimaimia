<template>
  <view class="nm-wish">
    <view class="nm-wish__header">
      <view class="nm-wish__author">
        <view class="nm-wish__avatar" />
        <view>
          <text class="nm-wish__name">{{ authorName }}</text>
          <text class="nm-wish__meta">{{ item.createdAt || '刚刚' }}</text>
        </view>
      </view>
      <view class="nm-wish__badges">
        <view :class="['nm-pill', statusTone]">
          <text class="nm-pill__text">{{ statusLabel }}</text>
        </view>
        <view class="nm-pill nm-pill--power">
          <text class="nm-pill__text">心愿力 · {{ item.power || 0 }}</text>
        </view>
      </view>
    </view>

    <text class="nm-wish__title" number-of-lines="2">{{ item.title }}</text>
    <text class="nm-wish__content" number-of-lines="3">{{ item.content }}</text>

    <view v-if="item.tags && item.tags.length" class="nm-wish__tags">
      <view v-for="tag in item.tags" :key="tag" class="nm-tag">
        <text class="nm-tag__text">{{ tag }}</text>
      </view>
      <view v-if="item.companyName" class="nm-tag nm-tag--accent">
        <text class="nm-tag__text">@{{ item.companyName }}</text>
      </view>
    </view>

    <view v-if="item.badges && item.badges.length" class="nm-wish__tags">
      <view v-for="badge in item.badges" :key="badge.id" class="nm-tag nm-tag--accent">
        <text class="nm-tag__text">{{ badge.label }}</text>
      </view>
    </view>

    <view class="nm-wish__footer">
      <view class="nm-wish__count">
        <text class="nm-wish__count-label">评论</text>
        <text class="nm-wish__count-value">{{ item.comments }}</text>
      </view>
      <view class="nm-wish__like">
        <text class="nm-wish__count-label">赞</text>
        <text class="nm-wish__count-value">{{ item.likes }}</text>
      </view>
    </view>
  </view>
</template>

<script>
// 心愿卡片（nvue）：心愿池发现流使用（公共组件需中文注释）
export default {
  props: {
    item: { type: Object, required: true },
  },
  computed: {
    authorName() {
      if (typeof this.item.author === 'string') return this.item.author;
      if (this.item.author && this.item.author.name) return this.item.author.name;
      return '匿名';
    },
    statusLabel() {
      const status = this.item.status || '规划中';
      if (status === 'done' || status === '已实现') return '已实现';
      if (status === 'adopted' || status === '已采纳') return '已采纳';
      return '规划中';
    },
    statusTone() {
      const status = this.item.status || '规划中';
      if (status === 'done' || status === '已实现') return 'nm-pill--accent';
      if (status === 'adopted' || status === '已采纳') return 'nm-pill--brand';
      return 'nm-pill--neutral';
    },
  },
};
</script>

<style scoped lang="scss">
