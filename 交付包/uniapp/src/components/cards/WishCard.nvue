  align-items: flex-end;
}

.nm-pill {
  padding: 6rpx 14rpx;
  border-radius: $nm-radius-pill;
  background-color: $nm-background;
  border: 1rpx solid $nm-border;
  margin-bottom: 6rpx;
}

.nm-pill__text {
  font-size: $nm-font-caption;
  color: $nm-text-secondary;
}

.nm-pill--brand {
  background-color: $nm-brand-primary-soft;
  border-color: transparent;
}

.nm-pill--brand .nm-pill__text {
  color: $nm-brand-primary;
}

.nm-pill--accent {
  background-color: $nm-accent-blue-soft;
  border-color: transparent;
}

.nm-pill--accent .nm-pill__text {
  color: $nm-accent-blue;
}

.nm-pill--power {
  background-color: $nm-brand-primary-soft;
  border-color: transparent;
}

.nm-pill--power .nm-pill__text {
  color: $nm-brand-primary;
}

.nm-wish__title {
  margin-top: $nm-space-sm;
  font-size: $nm-font-title3;
  line-height: $nm-line-title3;
  font-weight: 600;
  color: $nm-text-primary;
}

.nm-wish__content {
  margin-top: 6rpx;
  font-size: $nm-font-body;
  color: $nm-text-secondary;
}

.nm-wish__tags {
  margin-top: $nm-space-sm;
  flex-direction: row;
  flex-wrap: wrap;
}

.nm-tag {
  padding: 6rpx 14rpx;
  border-radius: $nm-radius-pill;
  background-color: $nm-background;
  border: 1rpx solid $nm-border;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

.nm-tag--accent {
  background-color: $nm-accent-blue-soft;
  border-color: transparent;
}

.nm-tag__text {
  font-size: $nm-font-caption;
  color: $nm-text-secondary;
}

.nm-tag--accent .nm-tag__text {
  color: $nm-accent-blue;
}

.nm-wish__footer {
  margin-top: $nm-space-sm;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.nm-wish__count {
  flex-direction: row;
  align-items: center;
}

.nm-wish__count-label {
  font-size: $nm-font-caption;
  color: $nm-text-secondary;
}

.nm-wish__count-value {
  margin-left: 6rpx;
  font-size: $nm-font-caption;
